# Doxygen config for Tankoban-3 — generates a browsable "encyclopedia" of the src/
# tree: class docs, file docs, inheritance + collaboration + call + caller graphs.
# Output is generated (gitignored), regenerate with: doxygen Doxyfile
PROJECT_NAME           = "Tankoban 3"
PROJECT_BRIEF          = "Harbor-in-Qt — native C++/Qt app"
OUTPUT_DIRECTORY       = docs/doxygen
INPUT                  = src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
HAVE_DOT               = YES
DOT_PATH               = "C:/Program Files/Graphviz/bin"
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_MULTI_TARGETS      = YES
QUIET                  = YES
WARNINGS               = NO
WARN_IF_UNDOCUMENTED   = NO
