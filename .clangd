# clangd config — points the portable C++ brain (clangd + clang-tidy, as used by
# VS Code / Codex / Claude / any LSP shell) at the compile database CLion already
# generates. That DB carries the REAL per-file flags (Qt6 + libtorrent + mpv includes,
# defines, C++20), so clangd parses Tankoban-3 with the same understanding CLion has —
# everywhere, not just inside JetBrains.
CompileFlags:
  CompilationDatabase: out
  # The DB is an MSVC (cl.exe) build; drop cl-only warning-control flags but keep
  # -external:I... include paths, because CMake emits Qt/mpv includes that way.
  Remove:
    - -external:W*
    - /external:W*
    - -Zc:*
    - /Zc:*
